# Optional maintainer-only credentials for advanced export scripts.
# Do not expose these values in browser code or committed files.
HF_TOKEN=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Browser runtime defaults.
VITE_TALKIE_ONNX_MODEL_ID=scasella91/talkie-1930-13b-it-ONNX
VITE_TALKIE_ONNX_REVISION=main

# Optional: cached or full. cached uses the KV-cache WebGPU path by default.
VITE_TALKIE_LOAD_PATH=cached

# Optional: q4f16, q8, fp16, fp32, or auto.
# auto means try q4f16 first, then q8 fallback.
VITE_TALKIE_ONNX_DTYPE=auto

# Optional: set to 1 to let Transformers.js write multi-GB model files into
# the browser cache. The app defaults this off to reduce duplicate large
# ArrayBuffer allocations while the Chrome/WebGPU load path is being hardened.
VITE_TALKIE_BROWSER_CACHE=0

# Optional: disabled, basic, extended, layout, or all.
# disabled is the browser-safe default for this large external-data graph.
VITE_TALKIE_GRAPH_OPTIMIZATION=disabled

# Optional: limit concurrent large Hugging Face model fetches in the browser.
# This avoids launching dozens of multi-hundred-MB external-data requests at once.
VITE_TALKIE_FETCH_CONCURRENCY=6
